# Production Environment - terraform.tfvars.example
# Copy this to terraform.tfvars and fill in the values

# AWS Region
aws_region = "sa-east-1"

# Domain
domain_name = "revendiste.com"

# Cloudflare (required)
cloudflare_api_token  = "your-cloudflare-api-token"
cloudflare_account_id = "your-cloudflare-account-id"

# RDS Configuration
db_instance_class        = "db.t4g.micro" # Upgrade to db.t4g.small (~$20/mo) when needed
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_backup_retention_days = 7

# ECS Backend
backend_cpu           = 512
backend_memory        = 1024
backend_desired_count = 1
backend_max_capacity  = 10

# ECS Frontend
frontend_cpu           = 256
frontend_memory        = 512
frontend_desired_count = 1
frontend_max_capacity  = 10

# Cronjobs
cronjob_cpu             = 256
cronjob_memory          = 512
cronjob_scraping_cpu    = 1024
cronjob_scraping_memory = 2048

# Logging
log_retention_days = 7

# Docker image tags
backend_image_tag  = "latest"
frontend_image_tag = "latest"

# R2 bucket location
r2_bucket_location = "WEUR"
