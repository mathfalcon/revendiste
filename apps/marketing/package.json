    "carousel:debug-slide": "tsx src/cli/debug-carousel-slide.ts",
    "carousel:full": "tsx src/cli/generate-carousel.ts -- --capture --cover",
    "carousel:capture": "tsx src/cli/generate-carousel.ts -- --capture",
    "carousel:pipeline": "tsx src/cli/carousel-pipeline.ts",
    "generate-ad": "tsx src/cli/generate-ad.ts",
    "publish": "tsx src/cli/publish.ts",
    "mcp": "tsx src/mcp/server.ts",
    "capture": "tsx src/screenshots/capture.ts",
    "capture:auth": "tsx src/screenshots/record-auth-state.ts",
    "type-check": "tsc --noEmit"
