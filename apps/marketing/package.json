  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/web/server.ts",
    "web": "tsx src/web/server.ts",
    "db": "kysely",
    "db:migrate": "kysely migrate:latest",
    "db:migrate:make": "kysely migrate:make",
    "db:codegen": "kysely-codegen --camel-case --dialect postgres --out-file src/db/types.ts",
