# Marketing Postgres (docker compose default)
MARKETING_DATABASE_URL=postgresql://marketing:marketing@localhost:5544/marketing

# Redis (BullMQ)
MARKETING_REDIS_URL=redis://localhost:6479

# MinIO (S3-compatible)
MARKETING_S3_ENDPOINT=http://localhost:9000
MARKETING_S3_REGION=us-east-1
MARKETING_S3_ACCESS_KEY=minioadmin
MARKETING_S3_SECRET_KEY=minioadmin
MARKETING_S3_BUCKET=revendiste-marketing
MARKETING_S3_FORCE_PATH_STYLE=true

# Web UI
MARKETING_WEB_PORT=4001

# Meta Marketing API
META_ACCESS_TOKEN=
# Must resolve to an Ad Account node (act_<digits>). Bare digits are auto-prefixed with act_.
META_AD_ACCOUNT_ID=act_
META_PAGE_ID=
# Traffic ad sets (promoted_object)
META_PIXEL_ID=

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
# Ad identity (Business Center / TT_USER)
TIKTOK_IDENTITY_ID=
# Uruguay targeting — TikTok Marketing API location id(s), comma-separated ok
TIKTOK_LOCATION_UY_ID=
# TIKTOK_LOCATION_UY_IDS=
TIKTOK_PIXEL_CODE=

# Optional: main backend Postgres for MCP event_lookup (events table)
# MAIN_DATABASE_URL=postgresql://...

# Frontend URL for Playwright screenshots
FRONTEND_URL=http://localhost:3000
