# Copy to .env and fill with real values. No secrets in this file.

NODE_ENV=local
LOG_LEVEL=info
PORT=3001

# Database (use DATABASE_URL or POSTGRES_*)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# Clerk (required)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# dLocal (required for payments)
DLOCAL_API_KEY=
DLOCAL_SECRET_KEY=
DLOCAL_BASE_URL=https://api.dlocal.com

# App URLs (required)
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# Storage (default: local)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_BASE_URL=http://localhost:3001

# Optional: AWS (when STORAGE_TYPE=s3)
# AWS_REGION=sa-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: Face Liveness
# FACE_LIVENESS_ROLE_ARN=

# Optional: Rate limiting (defaults: 60000 ms window, 100 max per IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100
